# ── Database ──
DATABASE_URL=postgresql+asyncpg://siakfin:siakfin@postgres:5432/siakfin
REDIS_URL=redis://redis:6379/0

# ── Telegram (https://my.telegram.org) ──
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNELS=

# ── GitHub Code Search ──
GITHUB_TOKEN=
GITHUB_POLL_INTERVAL=1800        # seconds (default 30 min)

# ── Google Custom Search (dork) ──
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_DORK_INTERVAL=3600        # seconds (default 1 hour)

# ── HaveIBeenPwned (optional) ──
HIBP_API_KEY=

# ── Auth ──
# Comma-separated list of valid X-API-Key values for write/report endpoints.
API_KEYS=sharkfin-demo-key-2026

# ── Data Protection (UU PDP No. 27/2022) ──
# false = hash-only mode: the original collected content is never persisted,
#         only the masked preview + SHA-256 hash. Recommended for production.
# true  = retain raw content (useful for local debugging / richer demo reports).
STORE_RAW_CONTENT=false

# ── App ──
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
